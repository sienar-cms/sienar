{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"Sienar": {
		"Core": {
			"EnableEmail": true,
			"SiteName": "Sienar example application",
			"SiteUrl": "http://localhost:5000"
		},
		"Email": {
			"Core": {
				"FromAddress": "no-reply@sienar.dev",
				"FromName": "Christian LeVesque",
				"Signature": "The Application Team"
			},
			"Smtp": {
				"Host": "smtp.sendgrid.net",
				"Port": 587
			},
			"IdentityEmailSubjects": {
				"WelcomeEmailSubject": "Wasssuuuuuppppp?"
			}
		},
		"Login": {
			"PersistentLoginDuration": 30,
			"TransientLoginDuration": 2,
			"RequireConfirmedAccount": true,
			"MaxFailedLoginAttempts": 5
		}
	}
}