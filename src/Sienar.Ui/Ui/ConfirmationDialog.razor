@inherits SienarComponentBase

<Card @UserAttributes="UserAttributes">
	<CardHeader
		TitleTag="h2"
		Color="MainColor">
		<Title>@Title</Title>
	</CardHeader>
	<CardContent>
		@Question
	</CardContent>

	<CardActions>
		<Button
			Color="MainColor"
			@onclick="@Confirm">
			@ConfirmText
		</Button>
		<Button
			Color="CancelColor"
			@onclick="@Cancel"
			Outlined>
			@CancelText
		</Button>
	</CardActions>
</Card>

@code {

	// [CascadingParameter]
	// private MudDialogInstance Dialog { get; set; } = null!;

	[Parameter]
	public required string Title { get; set; }

	[Parameter]
    public required string Question { get; set; }

	[Parameter]
	public required string ConfirmText { get; set; }

	[Parameter]
	public required string CancelText { get; set; }

	[Parameter]
	public Color MainColor { get; set; } = Color.Primary;

	[Parameter]
	public Color CancelColor { get; set; } = Color.Secondary;

	private void Confirm() {} /*Dialog.Close(DialogResult.Ok(true))*/

	private void Cancel() {} /*Dialog.Cancel()*/

}