@* ReSharper disable once CheckNamespace *@
@namespace Sienar.Ui
@inherits SienarComponentBase

<HtmlElement
	Tag="@Tag"
	@attributes="Attributes"
	class="@MergeCssClasses("card-content")">
	@ChildContent
</HtmlElement>

@code {

	/// <summary>
	/// The HTML tag with which to render the card content
	/// </summary>
	[Parameter]
	public string Tag { get; set; } = CardContentDefaults.Tag;

	/// <summary>
	/// The child content to render
	/// </summary>
	[Parameter]
    public required RenderFragment ChildContent { get; set; }

}