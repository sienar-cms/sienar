@inject IOptions<SiteOptions> Options

<PageTitle>
	@ComputedTitle
</PageTitle>

@code {

	private string? _subtitle;

	[Parameter]
	public string? Title { get; set; }

	[Parameter]
	public string Subtitle
	{
		get => _subtitle ?? Options.Value.Name;
		set => _subtitle = value;
	}

	private string ComputedTitle =>
		string.IsNullOrEmpty(Title)
			? Subtitle
			: $"{Title} | {Subtitle}";

}