@using Sienar.Infrastructure.Menus
@inherits SienarPage
@attribute [Route(DashboardUrls.Index)]

<DocTitle Title="Dashboard"/>

<Dashboard
	Categories="_menuNames"
	MenuGenerator="MenuGenerator"/>

@code {

	private readonly List<string> _menuNames = [
		SienarMenuNames.Dashboard.MyAccount
	];

	[Inject(Key = SienarBlazorUtilsServiceKeys.DashboardProvider)]
	private IMenuGenerator MenuGenerator { get; set; } = default!;

}