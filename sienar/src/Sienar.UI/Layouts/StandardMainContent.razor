<MudMainContent Class="@_mainContentClass">
	<MudContainer
		Class="@_containerClass"
		MaxWidth="MaxWidth.False">
		@ChildContent
	</MudContainer>
</MudMainContent>

@code {

	private string? _mainContentClass;
	private string _containerClass = default!;

	[Parameter]
	public required RenderFragment ChildContent { get; set; }

	[Parameter]
    public bool Padded { get; set; }

	[Parameter]
    public bool TopPadded { get; set; }

	/// <inheritdoc />
	protected override void OnInitialized()
	{
		if (Padded)
		{
			_mainContentClass = "px-16 pb-16";
		}

		_containerClass = TopPadded
			? "px-0 pt-16"
			: "px-0";
	}

}