<!DOCTYPE html>
<html
	class="d-flex flex-column min-vh-100"
	lang="en">
<head>
	{{> ui/head blurb=blurb pageTitle=pageTitle siteTitle=metadata.title }}
</head>
<body class="flex-grow-1 d-flex flex-column">

{{> ui/nav uri=page.url links=metadata.links }}

<div class="container flex-grow-1 pt-5">
	<div class="row">
		<div class="col-3">
			<section class="accordion position-sticky docs-sidebar">
				<a
					href="{{ backLink.url }}"
					class="d-block">
					{{ backLink.text }}
				</a>
				{{# each (lookup collections collectionName) }}
					<a
						href=" {{ this.url }}"
						class="d-block">
						{{ this.data.pageTitle }}
					</a>
				{{/each}}
			</section>
		</div>
		<div class="col-9 ps-5">
			{{{ content }}}
		</div>
	</div>
</div>

{{> ui/footer }}

</body>
</html>